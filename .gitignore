# Environment secrets — never commit the real .env file
.env

# OS / editor artifacts
.DS_Store
Thumbs.db
*.swp

.vs

# Service Bus emulator config — copy Config.example.json to Config.json
servicebus/Config.json

# .NET build artifacts (servicebus monitor tool)
servicebus/monitor/bin/
servicebus/monitor/obj/

# .NET build artifacts (servicebus proxy)
servicebus/proxy/bin/
servicebus/proxy/obj/

# Proxy-generated emulator config shards (created at runtime)
servicebus/emulator-configs/*
!servicebus/emulator-configs/.gitkeep

# Proxy state (persisted across restarts, deleted on nuke)
servicebus/proxy-state.json
/servicebus/Config.json
